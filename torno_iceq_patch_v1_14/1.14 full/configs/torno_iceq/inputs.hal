# INPUTS HAL - PREPARADO 7i96S

# Substituir pelos pinos reais depois

# Exemplo padrão Mesa:
# hm2_7i96s.0.gpio.000.in

# E-STOP
net estop-in <= hm2_7i96s.0.gpio.000.in
net estop-in => iocontrol.0.emc-enable-in

# CYCLE START
net cycle-start <= hm2_7i96s.0.gpio.001.in

# LUBRIFICAÇÃO
net lube-enable <= hm2_7i96s.0.gpio.002.in

