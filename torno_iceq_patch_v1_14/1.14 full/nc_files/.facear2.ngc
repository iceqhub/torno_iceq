(info: Facear)
o<.facear2> sub

#<z_ini>=#1      (=5 Z INICIAL)
#<z_fim>=#2    (=0 Z FINAL)
#<passada>=#3    (=1.5 PASSADA )
#<x_ini>=#4  (=100 X INICIAL)
#<x_fim>=#5   (=-1 X FINAL)
#<sobre_z>=#6    (=1 SOBREMETAL Z)
#<acaba>=#7    (=1 ACA 1=S 0=N 2=SÓ ACA)
#<canto>=#8    (=2 CANTO +=CHANFRO -=RAIO)
#<f_dsb>=#9   (=0.2 AVANÇO DSB)
#<f_acab>=#10   (=0.15 AVANÇO ACAB)
#<vcc>=#11   (=0 VCC)
#<RPM>=#12   (=1500 RPM)
#<afasta>=#13  (=2 RECUO EM X CICLO)
#<PONTO_TROCA_X>=#14  (=80 PONTO DE TROCA X)
#<PONTO_TROCA_Z>=#15  (=80 PONTO DE TROCA Z)
#<TOOL>=#16  (=0 NUMERO DA FERRAMENTA)
#<M8>=#17  (=8 OLEO SOLUVEL 9 DESLIGA)
#<afasta_z>=#18  (=1 RECUO EM Z CICLO)
#<final_pt>=#19   (=3 FINAL PONTO DE TROCA 0=NAO 1=XZ 2=ZX 3=JUNTOS)






O<G94>IF[#<f_dsb>GT1]
G94
O<G94>ELSE
G95
O<G94>ENDIF



O<aff>IF[#18eq0]
#<afasta_z>=2
O<aff>ENDIF

O<TROCA>IF[#<TOOL>GT0]
G43H#<TOOL>
G00G90X#<PONTO_TROCA_X>Z#<PONTO_TROCA_Z>
T[#<TOOL>]M6G43
O<TROCA>ENDIF


o<m3>if[#<RPM>lt0]

O<RPM>IF[abs[#<vcc>]EQ0]
G97S[abs[#<RPM>]]M4
O<RPM>ENDIF

O<VCC>IF[abs[#<vcc>]GT0]
G96S[abs[#<vcc>]]D[abs[#<RPM>]]M4
O<VCC>ENDIF

o<m3>else


O<RPM>IF[abs[#<vcc>]EQ0]
G97S[abs[#<RPM>]]M3
O<RPM>ENDIF

O<VCC>IF[abs[#<vcc>]GT0]
G96S[abs[#<vcc>]]D[abs[#<RPM>]]M3
O<VCC>ENDIF


o<m3>endif



M#<M8>


;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AJUSTE;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
#<z_fin_dsb>=[#<z_fim>+#<sobre_z>]
#<TOTAL>=[ABS[#<z_ini>]-ABS[#<z_fin_dsb>]]
O<DIRETO>IF[#<TOTAL>GT#<passada>]
#<NUM_D_PASS>=ROUND[#<TOTAL>/#<passada>]
#<passada>=[#<TOTAL>/#<NUM_D_PASS>]
O<DIRETO>ELSE
#<acaba>=2
O<DIRETO>ENDIF
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;



o<direito>if[#<x_ini>gt0]


#<zini>=#<z_ini>

o<dsb>if[#<acaba>ne2]

O100 while [#<NUM_D_PASS> GE 0]

G00 X[#<x_ini>+#<afasta>]
Z[#<z_ini>]
G01 F#<f_dsb> X#<x_fim>
Z[#<z_ini>+#<afasta_z>]
G0X[#<x_ini>+#<afasta>]
#<z_ini>=[#<z_ini>-#<passada>]
#<NUM_D_PASS>=[#<NUM_D_PASS>-1]
O100 endwhile

o<dsb>endif

o<acaba>if[#<acaba>ne0]

o<chanfro>if[#<canto>ne0]


o<ch>if[#<canto>gt0]

G00 X[#<x_ini>+#<afasta>]
Z[#<z_fim>+#<afasta_z>]
Z[#<z_fim>-#<canto>]
G01 F[#<f_acab>] X#<x_ini>
X[#<x_ini>-[#<canto>*2]]Z#<z_fim>
X#<x_fim>
G00 z[#<z_fim>+#<afasta_z>]
X[#<x_ini>+#<afasta>]

o<ch>else

#<canto>=ABS[#<canto>]

G00 X[#<x_ini>+#<afasta>]
Z[#<z_fim>+#<afasta_z>]
Z[#<z_fim>-#<canto>]
G01 F[#<f_acab>] X#<x_ini>


g02 X[#<x_ini>-[#<canto>*2]]Z#<z_fim> R#<canto>


g01X#<x_fim>
z[#<z_fim>+#<afasta_z>]
G00X[#<x_ini>+#<afasta>]

o<ch>endif




o<chanfro>else


G00 X[#<x_ini>+#<afasta>]
Z[#<z_fim>]
G01 F[#<f_acab>] X#<x_fim>
G00 z[#<z_fim>+#<afasta_z>]
X[#<x_ini>+#<afasta>]


o<chanfro>endif

o<acaba>endif
g00Z[#<zini>+#<afasta_z>]


o<direito>else



#<zini>=#<z_ini>

o<dsb2>if[#<acaba>ne2]

O1002 while [#<NUM_D_PASS> GE 0]

G00 X[#<x_ini>-#<afasta>]
Z[#<z_ini>]
G01 F#<f_dsb> X#<x_fim>
Z[#<z_ini>+#<afasta_z>]
G0X[#<x_ini>-#<afasta>]
#<z_ini>=[#<z_ini>-#<passada>]
#<NUM_D_PASS>=[#<NUM_D_PASS>-1]
O1002 endwhile

o<dsb2>endif

o<acaba>if[#<acaba>ne0]

o<chanfro>if[#<canto>ne0]


o<ch>if[#<canto>gt0]

G00 X[#<x_ini>-#<afasta>]
Z[#<z_fim>+#<afasta_z>]
Z[#<z_fim>-#<canto>]
G01 F[#<f_acab>] X#<x_ini>
X[#<x_ini>+[#<canto>*2]]Z#<z_fim>
X#<x_fim>
G00 z[#<z_fim>+#<afasta_z>]
X[#<x_ini>-#<afasta>]

o<ch>else

#<canto>=ABS[#<canto>]

G00 X[#<x_ini>-#<afasta>]
Z[#<z_fim>+#<afasta_z>]
Z[#<z_fim>-#<canto>]
G01 F[#<f_acab>] X#<x_ini>


g03 X[#<x_ini>+[#<canto>*2]]Z#<z_fim> R#<canto>


g01X#<x_fim>
z[#<z_fim>+#<afasta_z>]
G00X[#<x_ini>-#<afasta>]

o<ch>endif




o<chanfro>else


G00 X[#<x_ini>-#<afasta>]
Z[#<z_fim>]
G01 F[#<f_acab>] X#<x_fim>
G00 z[#<z_fim>+#<afasta_z>]
X[#<x_ini>-#<afasta>]


o<chanfro>endif

o<acaba>endif
g00Z[#<zini>+#<afasta_z>]








o<direito>endif


O<TROCA_FIM>IF[#<final_pt>NE0]

O<AMBOS>IF[#<final_pt>EQ3]
G00G90X#<PONTO_TROCA_X>Z#<PONTO_TROCA_Z>
O<AMBOS>ENDIF

O<XZ>IF[#<final_pt>EQ1]
G00G90X#<PONTO_TROCA_X>
Z#<PONTO_TROCA_Z>
O<XZ>ENDIF

O<ZX>IF[#<final_pt>EQ2]
G00G90Z#<PONTO_TROCA_Z>
X#<PONTO_TROCA_X>
O<ZX>ENDIF

O<TROCA_FIM>ENDIF




o<.facear2> endsub

