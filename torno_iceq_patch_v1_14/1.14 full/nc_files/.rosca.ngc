(info: Rosca)
o<.rosca> sub

#<diam_ini>=#1      (=50 DIAM. INICIAL)
#<diam_fina>=#2    (=0 DIAM. FINAL 0=calc. autom)
#<passada>=#3    (=0.25 PASSADA )
#<z_final>=#4  (=-30 PROF. EM Z)
#<recuo_z>=#5   (=5 RECUO DE SEG)
#<passo>=#6   (=2 PASSO DA ROSCA)
#<pass_vazio>=#7    (=3 PASS EM VAZIO)
#<ajuste_fino>=#8    (=0.0 AJUSTE FINO)
#<reppa>=#9    (=0 REPASSE =1)
#<RPM>=#10   (=1000 RPM)
#<afasta>=#11  (=4 RECUO EM X CICLO)
#<int_ext>=#12 (=0 0=EXTERNA 1=INTERNA  )
#<PONTO_TROCA_X>=#13  (=80 PONTO DE TROCA X)
#<PONTO_TROCA_Z>=#14  (=80 PONTO DE TROCA Z)
#<TOOL>=#15  (=0 NUMERO DA FERRAMENTA)
#<M8>=#16  (=8 OLEO SOLUVEL 9 DESLIGA)
#<final_pt>=#17   (=3 FINAL PONTO DE TROCA 0=NAO 1=XZ 2=ZX 3=JUNTOS)
#<tempo_rpm>=#18   (=0.0 TEMPO ESPERA ATINGIR RPM)
#<coni>=#19   (=0 ROSCA CONICA DIFERENCA DIAM FUNDO)


o<erro>if[#<int_ext>eq1]
o<erro1>if[#<diam_fina>eq0]
(msg,Informe o diametro final para rosca interna )
m30
o<erro1>endif
o<erro>endif


O<TROCA>IF[#<TOOL>GT0]
G43H#<TOOL>
G00G90X#<PONTO_TROCA_X>Z#<PONTO_TROCA_Z>
T[#<TOOL>]M6G43
O<TROCA>ENDIF


M#<M8>

G97S#<RPM>M3

G4P#<tempo_rpm>

o<esquerdo>if[#<diam_ini>gt0]





#<diam_ini>=#<diam_ini>

O<EXT>IF[#<int_ext>eq0]

o<calcula>if[#<diam_fina>eq0]
#<altura>=[0.65*#<passo>]
#<diam_fina>=[#<diam_ini>-[2*#<altura>]]
o<calcula>endif

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AJUSTE;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
#<diam_ini>=[#<diam_ini>-#<passada>]
#<TOTAL>=[#<diam_ini>-#<diam_fina>]
O<DIRETO>IF[#<TOTAL>GT#<passada>]
#<NUM_D_PASS>=ROUND[#<TOTAL>/#<passada>]
#<passada>=[#<TOTAL>/#<NUM_D_PASS>]
O<DIRETO>ELSE
#<reppa>=1
O<DIRETO>ENDIF
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

O<REPP>IF[#<reppa>NE1]

O104 while [#<NUM_D_PASS> GE 0]
G00 X[#<diam_ini>+#<ajuste_fino>]
G00 Z#<recuo_z>
G33 K#<passo> X[#<diam_ini>+#<ajuste_fino>+#<coni>] Z[#<z_final>]



;g94
;G01 f1000 Z[#<z_final>]

G00 X[#<diam_ini>+#<afasta>+#<coni>]
Z#<recuo_z>
#<diam_ini>=[#<diam_ini>-#<passada>]
#<NUM_D_PASS>=[#<NUM_D_PASS>-1]
O104 endwhile

O<REPP>ENDIF

O105 WHILE [#<pass_vazio>GT0]
G00 X[#<diam_fina>+#<ajuste_fino>]
G00 Z#<recuo_z>
G33 K#<passo> X[#<diam_fina>+#<ajuste_fino>+#<coni>] Z[#<z_final>]

;g94
;G01 f1000 Z[#<z_final>]

G00 X[#<diam_ini>+#<afasta>+#<coni>]
Z#<recuo_z>
#<pass_vazio>=[#<pass_vazio>-1]
O105 ENDWHILE 

O<EXT>ELSE

O<REPP1>IF[#<reppa>NE1]

o<calculaerro>if[#<diam_fina>eq0]

(msg,Calcule o diametro Final )

o<calculaerro>endif

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AJUSTE;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
#<diam_ini>=[#<diam_ini>+#<passada>]
#<TOTAL>=[#<diam_fina>-#<diam_ini>]
O<DIRETO1>IF[#<TOTAL>GT#<passada>]
#<NUM_D_PASS>=ROUND[#<TOTAL>/#<passada>]
#<passada>=[#<TOTAL>/#<NUM_D_PASS>]
O<DIRETO1>ELSE
#<reppa>=1
O<DIRETO1>ENDIF
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;




O106 while [#<NUM_D_PASS> GE 0]
G00 X[#<diam_ini>-#<ajuste_fino>]
G00 Z#<recuo_z>
G33 K#<passo> X[#<diam_ini>-#<ajuste_fino>-#<coni>] Z[#<z_final>]

;g94
;G01 f1000 Z[#<z_final>]

G00 X[#<diam_ini>-#<afasta>-#<coni>]
Z#<recuo_z>
#<diam_ini>=[#<diam_ini>+#<passada>]
#<NUM_D_PASS>=[#<NUM_D_PASS>-1]
O106 endwhile

O<REPP1>ENDIF

O107 WHILE [#<pass_vazio>GT0]
G00 X[#<diam_fina>-#<ajuste_fino>]
G00 Z#<recuo_z>
G33 K#<passo> X[#<diam_fina>-#<ajuste_fino>-#<coni>] Z[#<z_final>]

;g94
;G01 f1000 Z[#<z_final>]

G00 X[#<diam_ini>-#<afasta>-#<coni>]
Z#<recuo_z>
#<pass_vazio>=[#<pass_vazio>-1]
O107 ENDWHILE 

O<EXT>ENDIF



o<esquerdo>else



#<diam_ini>=#<diam_ini>

O<EXT>IF[#<int_ext>eq0]



o<calcula>if[#<diam_fina>eq0]
#<altura>=[0.65*#<passo>]
#<diam_fina>=[#<diam_ini>+[2*#<altura>]]
o<calcula>endif

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AJUSTE;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
#<diam_ini>=[#<diam_ini>+#<passada>]
#<TOTAL>=abs[#<diam_ini>-#<diam_fina>]
O<DIRETO>IF[#<TOTAL>GT#<passada>]
#<NUM_D_PASS>=ROUND[#<TOTAL>/#<passada>]
#<passada>=[#<TOTAL>/#<NUM_D_PASS>]
O<DIRETO>ELSE
#<reppa>=1
O<DIRETO>ENDIF
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;





O<REPP1>IF[#<reppa>NE1]

O106 while [#<NUM_D_PASS> GE 0]
G00 X[#<diam_ini>-#<ajuste_fino>]
G00 Z#<recuo_z>
G33 K#<passo> Z[#<z_final>]

;g94
;G01 f1000 Z[#<z_final>]

G00 X[#<diam_ini>-#<afasta>]
Z#<recuo_z>
#<diam_ini>=[#<diam_ini>+#<passada>]
#<NUM_D_PASS>=[#<NUM_D_PASS>-1]
O106 endwhile

O<REPP1>ENDIF

O107 WHILE [#<pass_vazio>GT0]
G00 X[#<diam_fina>-#<ajuste_fino>]
G00 Z#<recuo_z>
G33 K#<passo> Z[#<z_final>]

;g94
;G01 f1000 Z[#<z_final>]

G00 X[#<diam_ini>-#<afasta>]
Z#<recuo_z>
#<pass_vazio>=[#<pass_vazio>-1]
O107 ENDWHILE 

O<EXT>ELSE


o<calculaerro2>if[#<diam_fina>eq0]

(msg,Calcule o diametro Final )

o<calculaerro2>endif

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AJUSTE;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
#<diam_ini>=[#<diam_ini>-#<passada>]
#<TOTAL>=[#<diam_ini>-#<diam_fina>]
O<DIRETO1>IF[#<TOTAL>GT#<passada>]
#<NUM_D_PASS>=ROUND[#<TOTAL>/#<passada>]
#<passada>=[#<TOTAL>/#<NUM_D_PASS>]
O<DIRETO1>ELSE
#<reppa>=1
O<DIRETO1>ENDIF
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;



O<REPP>IF[#<reppa>NE1]




O104 while [#<NUM_D_PASS> GE 0]
G00 X[#<diam_ini>+#<ajuste_fino>]
G00 Z#<recuo_z>
G33 K#<passo> Z[#<z_final>]

;g94
;G01 f1000 Z[#<z_final>]

G00 X[#<diam_ini>+#<afasta>]
Z#<recuo_z>
#<diam_ini>=[#<diam_ini>-#<passada>]
#<NUM_D_PASS>=[#<NUM_D_PASS>-1]
O104 endwhile

O<REPP>ENDIF

O105 WHILE [#<pass_vazio>GT0]
G00 X[#<diam_fina>+#<ajuste_fino>]
G00 Z#<recuo_z>
G33 K#<passo> Z[#<z_final>]

;g94
;G01 f1000 Z[#<z_final>]

G00 X[#<diam_ini>+#<afasta>]
Z#<recuo_z>
#<pass_vazio>=[#<pass_vazio>-1]
O105 ENDWHILE 





O<EXT>ENDIF








o<esquerdo>endif



O<TROCA_FIM>IF[#<final_pt>NE0]

O<AMBOS>IF[#<final_pt>EQ3]
G00G90X#<PONTO_TROCA_X>Z#<PONTO_TROCA_Z>
O<AMBOS>ENDIF

O<XZ>IF[#<final_pt>EQ1]
G00G90X#<PONTO_TROCA_X>
Z#<PONTO_TROCA_Z>
O<XZ>ENDIF

O<ZX>IF[#<final_pt>EQ2]
G00G90Z#<PONTO_TROCA_Z>
X#<PONTO_TROCA_X>
O<ZX>ENDIF

O<TROCA_FIM>ENDIF




o<.rosca> endsub

