(info: Furacao)
o<.furacao> sub


#<Z_INI>=#1      (=2 Z INICIAL)
#<Z_FINA>=#2    (=-8 Z FINAL)
#<PASSADA>=#3    (=2 PASSADA )
#<TOOL>=#4    (=0 NUMERO DA FERRAMENTA)
#<AVANCO>=#5   (=0.02 Avanço)
#<CICLO>=#6    (=73 G81 G83 G73)
#<RPM>=#7   (=1500 RPM)
#<PONTO_TROCA_X>=#8  (=200 PONTO DE TROCA X)
#<PONTO_TROCA_Z>=#9  (=50 PONTO DE TROCA Z)
#<M8>=#10  (=8 OLEO SOLUVEL 9 DESLIGA)
#<final_pt>=#11   (=3 FINAL PONTO DE TROCA 0=NAO 1=XZ 2=ZX 3=JUNTOS)





O<TROCA>IF[#<TOOL>GT0]
G43H#<TOOL>
G00G90X#<PONTO_TROCA_X>Z#<PONTO_TROCA_Z>
T[#<TOOL>]M6G43
O<TROCA>ENDIF



M#<M8>



o<m3>if[#<RPM>lt0]

G97S[abs[#<RPM>]]M4

o<m3>else

G97S[abs[#<RPM>]]M3

o<m3>endif





G00 Z#<Z_INI>
X0

o<g81>if[#<CICLO>eq81]
G17

G81 R#<Z_INI> Z#<Z_FINA> F#<AVANCO>  

G18

o<g81>else

G17

G#<CICLO> R#<Z_INI> Z#<Z_FINA> Q#<PASSADA> F#<AVANCO>  

G18

o<g81>endif



O<TROCA_FIM>IF[#<final_pt>NE0]

O<AMBOS>IF[#<final_pt>EQ3]
G00G90X#<PONTO_TROCA_X>Z#<PONTO_TROCA_Z>
O<AMBOS>ENDIF

O<XZ>IF[#<final_pt>EQ1]
G00G90X#<PONTO_TROCA_X>
Z#<PONTO_TROCA_Z>
O<XZ>ENDIF

O<ZX>IF[#<final_pt>EQ2]
G00G90Z#<PONTO_TROCA_Z>
X#<PONTO_TROCA_X>
O<ZX>ENDIF

O<TROCA_FIM>ENDIF



o<.furacao> endsub

