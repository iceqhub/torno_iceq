# INPUTS HAL - 1.16
# Responsabilidade:
# Somente entradas físicas e sinais lógicos básicos

# E-STOP
net estop-in <= hm2_7i96s.0.gpio.000.in
net estop-in => iocontrol.0.emc-enable-in

# CYCLE START
net cycle-start <= hm2_7i96s.0.gpio.001.in

# LUBRIFICACAO
net lube-enable <= hm2_7i96s.0.gpio.002.in

# HOME X
net home-x <= hm2_7i96s.0.gpio.003.in

# HOME Z
net home-z <= hm2_7i96s.0.gpio.004.in

# SPARE INPUTS
