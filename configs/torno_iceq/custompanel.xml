<?xml version='1.0' encoding='UTF-8'?>
<!-- custompanel.xml — Versão 4.0 -->
<!-- Adicionado: controles MPG (eixo, escala), feed override display -->

<pyvcp>

  <!-- ======================================================== -->
  <!-- TÍTULO -->
  <!-- ======================================================== -->
  <labelframe text="TORNO ICEQ" relief="ridge" bd="2">
    <label>
      <text>"LinuxCNC + Mesa 7i96S"</text>
      <font>('Helvetica', 9, 'bold')</font>
    </label>
  </labelframe>

  <!-- ======================================================== -->
  <!-- STATUS DA MÁQUINA -->
  <!-- ======================================================== -->
  <labelframe text="Status" relief="groove" bd="2">
    <hbox>
      <vbox>
        <label><text>"Máquina ON"</text></label>
        <led>
          <halpin>"led-machine-on"</halpin>
          <size>16</size>
          <on_color>"green"</on_color>
          <off_color>"red"</off_color>
        </led>
      </vbox>
      <vbox>
        <label><text>"Em posição"</text></label>
        <led>
          <halpin>"led-in-position"</halpin>
          <size>16</size>
          <on_color>"green"</on_color>
          <off_color>"gray"</off_color>
        </led>
      </vbox>
      <vbox>
        <label><text>"Rodando"</text></label>
        <led>
          <halpin>"led-prog-running"</halpin>
          <size>16</size>
          <on_color>"lime green"</on_color>
          <off_color>"gray"</off_color>
        </led>
      </vbox>
      <vbox>
        <label><text>"Pausado"</text></label>
        <led>
          <halpin>"led-prog-paused"</halpin>
          <size>16</size>
          <on_color>"yellow"</on_color>
          <off_color>"gray"</off_color>
        </led>
      </vbox>
    </hbox>
  </labelframe>

  <!-- ======================================================== -->
  <!-- SPINDLE RPM -->
  <!-- ======================================================== -->
  <labelframe text="Spindle" relief="groove" bd="2">
    <hbox>
      <label><text>"RPM:"</text></label>
      <number>
        <halpin>"spindle-rpm"</halpin>
        <font>('Helvetica', 14, 'bold')</font>
        <format>"%6.0f"</format>
      </number>
    </hbox>
    <bar>
      <halpin>"spindle-rpm"</halpin>
      <min_>0</min_>
      <max_>1200</max_>
      <bgcolor>"gray"</bgcolor>
      <fillcolor>"blue"</fillcolor>
    </bar>
  </labelframe>

  <!-- ======================================================== -->
  <!-- TIMER DE CICLO -->
  <!-- ======================================================== -->
  <labelframe text="Tempo de Ciclo" relief="groove" bd="2">
    <hbox>
      <label><text>"Tempo (s):"</text></label>
      <number>
        <halpin>"timer-value"</halpin>
        <font>('Helvetica', 14, 'bold')</font>
        <format>"%8.1f"</format>
      </number>
    </hbox>
  </labelframe>

  <!-- ======================================================== -->
  <!-- POSIÇÕES -->
  <!-- ======================================================== -->
  <labelframe text="Posição" relief="groove" bd="2">
    <hbox>
      <label><text>"X:"</text></label>
      <number>
        <halpin>"x-pos"</halpin>
        <font>('Helvetica', 12, 'bold')</font>
        <format>"%8.4f"</format>
      </number>
    </hbox>
    <hbox>
      <label><text>"Z:"</text></label>
      <number>
        <halpin>"z-pos"</halpin>
        <font>('Helvetica', 12, 'bold')</font>
        <format>"%8.4f"</format>
      </number>
    </hbox>
  </labelframe>

  <!-- ======================================================== -->
  <!-- HANDWHEEL MPG — SELEÇÃO DE EIXO -->
  <!-- ======================================================== -->
  <labelframe text="Handwheel — Eixo" relief="ridge" bd="2">
    <hbox>
      <!-- Botão de alternância X / Z -->
      <button>
        <halpin>"btn-sel-axis"</halpin>
        <text>"TROCAR EIXO"</text>
        <font>('Helvetica', 10, 'bold')</font>
        <bg>"steel blue"</bg>
        <activebackground>"dodger blue"</activebackground>
        <fg>"white"</fg>
      </button>
      <vbox>
        <hbox>
          <label><text>"X"</text><font>('Helvetica', 12, 'bold')</font></label>
          <led>
            <halpin>"led-sel-x"</halpin>
            <size>20</size>
            <on_color>"green"</on_color>
            <off_color>"gray"</off_color>
          </led>
        </hbox>
        <hbox>
          <label><text>"Z"</text><font>('Helvetica', 12, 'bold')</font></label>
          <led>
            <halpin>"led-sel-z"</halpin>
            <size>20</size>
            <on_color>"green"</on_color>
            <off_color>"gray"</off_color>
          </led>
        </hbox>
      </vbox>
    </hbox>
  </labelframe>

  <!-- ======================================================== -->
  <!-- HANDWHEEL MPG — SELEÇÃO DE ESCALA -->
  <!-- Radiogroup retorna o value do item selecionado diretamente -->
  <!-- ======================================================== -->
  <labelframe text="Handwheel — Escala (pol/pulso)" relief="ridge" bd="2">
    <radiobutton>
      <choices>["0.001","0.010","0.100","1.000"]</choices>
      <values>[0.001, 0.010, 0.100, 1.000]</values>
      <halpin>"mpg-scale"</halpin>
      <initval>0.010</initval>
      <font>('Helvetica', 10, 'bold')</font>
    </radiobutton>
  </labelframe>

  <!-- ======================================================== -->
  <!-- FEED OVERRIDE (display) -->
  <!-- ======================================================== -->
  <labelframe text="Feed Override" relief="groove" bd="2">
    <hbox>
      <label><text>"FO:"</text></label>
      <number>
        <halpin>"feed-override-val"</halpin>
        <font>('Helvetica', 12, 'bold')</font>
        <format>"%5.0f"</format>
      </number>
      <label><text>"%"</text></label>
    </hbox>
  </labelframe>

  <!-- ======================================================== -->
  <!-- SPINDLE MANUAL (botões) -->
  <!-- ======================================================== -->
  <labelframe text="Spindle Manual" relief="groove" bd="2">
    <hbox>
      <button>
        <halpin>"spindle-manual-cw"</halpin>
        <text>"▶ CW"</text>
        <bg>"dark green"</bg>
        <fg>"white"</fg>
        <font>('Helvetica', 10, 'bold')</font>
      </button>
      <button>
        <halpin>"spindle-manual-stop"</halpin>
        <text>"■ STOP"</text>
        <bg>"dark red"</bg>
        <fg>"white"</fg>
        <font>('Helvetica', 10, 'bold')</font>
      </button>
      <button>
        <halpin>"spindle-manual-ccw"</halpin>
        <text>"◀ CCW"</text>
        <bg>"dark green"</bg>
        <fg>"white"</fg>
        <font>('Helvetica', 10, 'bold')</font>
      </button>
    </hbox>
  </labelframe>

</pyvcp>
