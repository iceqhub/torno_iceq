<?xml version='1.0' encoding='UTF-8'?>
<pyvcp>

<tabs>
    <names>["Geral", "Tempo e Contador", "Limites", "Manutencao"]</names>
    <vbox> <!-- Geral -->

<!-- RPM: max ajustado para 1500 conforme relação de polia do servo -->
<labelframe text="RPM">
<font>("Helvetica",10)</font>
    <bar>
        <halpin>"spindle-speed"</halpin>
        <max_>1500</max_>
    </bar>
    <hbox>
        <label>
            <text>"RPM OK:"</text>
            <font>("Helvetica",10)</font>
        </label>
        <led>
            <halpin>"spindle-at-speed-led"</halpin>
            <size>15</size>
            <on_color>"green"</on_color>
            <off_color>"red"</off_color>
        </led>
    </hbox>
</labelframe>

<!-- ======================================================== -->
<!-- LIBERAR SPINDLE                                           -->
<!-- ======================================================== -->
<labelframe text="Spindle">
<font>("Helvetica",10)</font>
    <checkbutton>
        <halpin>"liberar-spindle"</halpin>
        <text>"  LIBERAR SPINDLE (SON OFF)  "</text>
        <font>("Helvetica",13,"bold")</font>
    </checkbutton>
    <label>
        <text>"Funcao fora do padrao CNC — adicionada"</text>
        <font>("Helvetica",8)</font>
    </label>
    <label>
        <text>"por opcao do operador para permitir"</text>
        <font>("Helvetica",8)</font>
    </label>
    <label>
        <text>"rotacao manual da placa (troca de peca)."</text>
        <font>("Helvetica",8)</font>
    </label>
    <label>
        <text>"NAO marcar com spindle em movimento."</text>
        <font>("Helvetica",8,"bold")</font>
    </label>
</labelframe>
<!-- FIM LIBERAR SPINDLE -->

<!-- ======================================================== -->
<!-- HANDWHEEL MPG                                             -->
<!-- ======================================================== -->
<labelframe text="Handwheel">
<font>("Helvetica",10)</font>
    <checkbutton>
        <halpin>"btn-x"</halpin>
        <text>"  Eixo X  "</text>
        <font>("Helvetica",15,"bold")</font>
    </checkbutton>
    <checkbutton>
        <halpin>"btn-z"</halpin>
        <text>"  Eixo Z  "</text>
        <font>("Helvetica",15,"bold")</font>
    </checkbutton>
    <label><text>" "</text></label>
    <checkbutton>
        <halpin>"mpg-sel0"</halpin>
        <text>"  x10  (0.010 / 1.000)  "</text>
        <font>("Helvetica",12)</font>
    </checkbutton>
    <checkbutton>
        <halpin>"mpg-sel1"</halpin>
        <text>"  x100 (0.100 / 1.000)  "</text>
        <font>("Helvetica",12)</font>
    </checkbutton>
    <number>
        <halpin>"mpg-scale-disp"</halpin>
        <font>("Helvetica",18,"bold")</font>
        <format>"6.3f"</format>
    </number>
</labelframe>

<labelframe text="Troca Ferramenta">
<font>("Helvetica",10)</font>
    <hbox>
        <button><halpin>"tool-1"</halpin><text>"T01"</text><bd>3</bd></button>
        <button><halpin>"tool-2"</halpin><text>"T02"</text><bd>3</bd></button>
        <button><halpin>"tool-3"</halpin><text>"T03"</text><bd>3</bd></button>
        <button><halpin>"tool-4"</halpin><text>"T04"</text><bd>3</bd></button>
    </hbox>
    <hbox>
        <button><halpin>"tool-5"</halpin><text>"T05"</text><bd>3</bd></button>
        <button><halpin>"tool-6"</halpin><text>"T06"</text><bd>3</bd></button>
        <button><halpin>"tool-7"</halpin><text>"T07"</text><bd>3</bd></button>
        <button><halpin>"tool-8"</halpin><text>"T08"</text><bd>3</bd></button>
    </hbox>
    <hbox>
        <button><halpin>"tool-9"</halpin><text>"T09"</text><bd>3</bd></button>
        <button><halpin>"tool-10"</halpin><text>"T10"</text><bd>3</bd></button>
        <button><halpin>"tool-11"</halpin><text>"T11"</text><bd>3</bd></button>
        <button><halpin>"tool-12"</halpin><text>"T12"</text><bd>3</bd></button>
    </hbox>
    <hbox>
        <button><halpin>"tool-13"</halpin><text>"T13"</text><bd>3</bd></button>
        <button><halpin>"tool-14"</halpin><text>"T14"</text><bd>3</bd></button>
        <button><halpin>"tool-15"</halpin><text>"T15"</text><bd>3</bd></button>
        <button><halpin>"tool-16"</halpin><text>"T16"</text><bd>3</bd></button>
    </hbox>
    <labelframe text="Ferramenta Ativa">
    <font>("Helvetica",10)</font>
        <hbox>
            <s32>
                <halpin>"tool-number"</halpin>
                <font>("Helvetica",10)</font>
                <format>"2d"</format>
                <width>2</width>
            </s32>
        </hbox>
    </labelframe>
</labelframe>

<hbox>
    <label><text>"Tempo Ciclo"</text><font>("Helvetica",12)</font></label>
    <u32><halpin>"time-hours"</halpin><font>("Helvetica",12)</font><format>"2d"</format></u32>
    <label><text>":"</text><font>("Helvetica",12)</font></label>
    <u32><halpin>"time-minutes"</halpin><font>("Helvetica",12)</font><format>"2d"</format></u32>
    <label><text>":"</text><font>("Helvetica",12)</font></label>
    <u32><halpin>"time-seconds"</halpin><font>("Helvetica",12)</font><format>"2d"</format></u32>
</hbox>

<button><halpin>"seta-x"</halpin><text>"     SETA-X-EXTERNO  "</text><bd>8</bd></button>
<button><halpin>"seta-xneg"</halpin><text>"     SETA-X-INTERNO  "</text><bd>8</bd></button>
<button><halpin>"seta-z"</halpin><text>"     SETA-Z          "</text><bd>8</bd></button>
<button><halpin>"seta-z-neg"</halpin><text>"SETA-Z-NEG-CONTRA-PONTA"</text><bd>8</bd></button>
<button><halpin>"restaura"</halpin><text>"    RESTAURA         "</text><bd>8</bd></button>

<labelframe text="Emergencia">
<font>("Helvetica",10)</font>
    <vbox>
        <hbox>
            <led>
                <halpin>"led-xz"</halpin>
                <size>20</size>
                <on_color>"green"</on_color>
                <off_color>"red"</off_color>
            </led>
            <label text="Drivers X Z C B SPINDLE"/>
        </hbox>
        <hbox>
            <led>
                <halpin>"led-emg-but"</halpin>
                <size>20</size>
                <on_color>"red"</on_color>
                <off_color>"green"</off_color>
            </led>
            <label text="Botao de EMG"/>
        </hbox>
    </vbox>
</labelframe>

    </vbox>

    <vbox> <!-- Tempo e Contador -->
        <vbox>
            <relief>RIDGE</relief>
            <bd>6</bd>
            <hbox>
                <label><text>"QNT-PECAS"</text><font>("Helvetica",12)</font></label>
                <s32><halpin>"PECAS"</halpin><font>("Helvetica",12)</font><format>"2d"</format></s32>
            </hbox>
            <button><halpin>"reset"</halpin><text>"Seta Contador"</text><bd>3</bd></button>
            <labelframe text="MODO MANUAL"><font>("Helvetica",10)</font></labelframe>
            <spinbox>
                <halpin>"preset"</halpin>
                <min_>0</min_>
                <max_>3000</max_>
                <initval>0</initval>
                <resolution>1</resolution>
                <format>"2.0f"</format>
                <font>("Arial",12)</font>
            </spinbox>
        </vbox>
    </vbox>

    <vbox> <!-- Limites -->
        <vbox>
            <relief>RIDGE</relief>
            <bd>6</bd>
        </vbox>
    </vbox>

    <vbox> <!-- Manutencao -->

        <labelframe text="PLACA">
        <font>("Helvetica",10)</font>
            <hbox>
                <button><halpin>"abrir"</halpin><text>"ABRE"</text><bd>3</bd></button>
                <led><halpin>"LED-ABRE"</halpin><size>15</size><on_color>"green"</on_color><off_color>"black"</off_color></led>
            </hbox>
            <hbox>
                <button><halpin>"fechar"</halpin><text>"FECHA"</text><bd>3</bd></button>
                <led><halpin>"LED-FECHA"</halpin><size>15</size><on_color>"green"</on_color><off_color>"black"</off_color></led>
            </hbox>
        </labelframe>

        <labelframe text="CONTRA-PONTA">
        <font>("Helvetica",10)</font>
            <hbox>
                <button><halpin>"recua"</halpin><text>"RECUA"</text><bd>3</bd></button>
                <led><halpin>"LED-RECUA"</halpin><size>15</size><on_color>"green"</on_color><off_color>"black"</off_color></led>
            </hbox>
            <hbox>
                <button><halpin>"avanca"</halpin><text>"AVANCA"</text><bd>3</bd></button>
                <led><halpin>"LED-AVANCA"</halpin><size>15</size><on_color>"green"</on_color><off_color>"black"</off_color></led>
            </hbox>
        </labelframe>

        <labelframe text="Adaptive-Feed">
        <font>("Helvetica",10)</font>
            <button><halpin>"ativa"</halpin><text>"ativa"</text><bd>3</bd></button>
            <button><halpin>"desativa"</halpin><text>"desativa"</text><bd>3</bd></button>
        </labelframe>

        <labelframe text="POS-Encoder-Torre">
        <font>("Helvetica",10)</font>
            <hbox>
                <number>
                    <halpin>"pos-encoder"</halpin>
                    <font>("Helvetica",10)</font>
                    <format>"2d"</format>
                    <width>4</width>
                </number>
            </hbox>
        </labelframe>

        <labelframe text="Solenoide">
        <font>("Helvetica",10)</font>
            <hbox>
                <button><halpin>"solenoide"</halpin><text>"Ativa"</text><bd>8</bd></button>
            </hbox>
        </labelframe>

        <labelframe text="Girar-torre">
        <font>("Helvetica",10)</font>
            <hbox>
                <button><halpin>"gira-cw-py"</halpin><text>"CW"</text><bd>8</bd></button>
            </hbox>
            <hbox>
                <button><halpin>"gira-ccw-py"</halpin><text>"CCW"</text><bd>8</bd></button>
            </hbox>
        </labelframe>

        <labelframe text="Reset">
        <font>("Helvetica",10)</font>
            <hbox>
                <button><halpin>"resetar"</halpin><text>"Reset"</text><bd>8</bd></button>
            </hbox>
        </labelframe>

    </vbox>

</tabs>

</pyvcp>
