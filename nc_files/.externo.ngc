(info: Desbaste Externo)
o<.externo> sub

#<diam_ini>=#1      (=50 DIAM INI)
#<diam_fina>=#2    (=25 DIAM FINAL)
#<passada>=#3    (=2 PASSADA )
#<prof_z>=#4  (=-20 PROF Z ABS)
#<raio_fundo>=#5    (=0 FUNDO +=CHANFRO -=RAIO)
#<chanfro>=#6    (=0 TAMANHO DO CHANFRO FUNDO)
#<z_ini>=#7   (=0 Z INICIAL)
#<recuo_z>=#8   (=2 RECUO Z)
#<sobre_x>=#9    (=1.5 SOBREMETAL X)
#<sobre_z>=#10    (=0.15 SOBREMETAL Z)
#<CONI>=#11    (=0.00 CONICIDADE)
#<acaba>=#12    (=1 ACA 1=S 0=N 2=SÓ ACA)
#<canto>=#13    (=2 CANTO +=CHANFRO -=RAIO)
#<f_dsb>=#14   (=0.2 AVANÇO DSB)
#<f_acab>=#15   (=0.15 AVANÇO ACAB)
#<vcc>=#16   (=0 VCC)
#<RPM>=#17   (=1500 RPM)
#<PONTO_TROCA_X>=#18  (=80 PONTO DE TROCA X)
#<PONTO_TROCA_Z>=#19  (=80 PONTO DE TROCA Z)
#<TOOL>=#20  (=0 NUMERO DA FERRAMENTA)
#<M8>=#21  (=8 OLEO SOLUVEL 9 DESLIGA)
#<recuo_x>=#22   (=2 RECUO EM X NO CICLO)
#<facea>=#23   (=0 FACEA FUNDO)
#<final_pt>=#24   (=3 FINAL PONTO DE TROCA 0=NAO 1=XZ 2=ZX 3=JUNTOS)



o<erro>if[#<raio_fundo>gt0]
o<erro1>if[#<chanfro>le0]
(msg,Ao usar Chanfro no fundo Determine o Tamanho )
m30
o<erro1>endif
o<erro>endif




O<aff>IF[#19eq0]
#<recuo_x>=2
O<aff>ENDIF


O<G94>IF[#<f_dsb>GT1]
G94
O<G94>ELSE
G95
O<G94>ENDIF

O<TROCA>IF[#<TOOL>GT0]
G43H#<TOOL>
G00G90X#<PONTO_TROCA_X>Z#<PONTO_TROCA_Z>
T[#<TOOL>]M6G43
O<TROCA>ENDIF




o<m3>if[#<RPM>lt0]

O<RPM>IF[abs[#<vcc>]EQ0]
G97S[abs[#<RPM>]]M4
O<RPM>ENDIF

O<VCC>IF[abs[#<vcc>]GT0]
G96S[abs[#<vcc>]]D[abs[#<RPM>]]M4
O<VCC>ENDIF

o<m3>else


O<RPM>IF[abs[#<vcc>]EQ0]
G97S[abs[#<RPM>]]M3
O<RPM>ENDIF

O<VCC>IF[abs[#<vcc>]GT0]
G96S[abs[#<vcc>]]D[abs[#<RPM>]]M3
O<VCC>ENDIF


o<m3>endif






M#<M8>


o<esquerdo>if[#<diam_ini>gt0]

O<com_raio>if[#<raio_fundo>lt0]

#<raio_fundu>=ABS[#<raio_fundo>]

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;COM RAIO;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AJUSTE;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
#<diam_fina_dsb>=[#<diam_fina>+#<sobre_x>]
#<TOTAL>=[#<diam_ini>-#<diam_fina_dsb>]
O<DIRETO1>IF[#<TOTAL>GT#<passada>]
#<NUM_D_PASS>=ROUND[#<TOTAL>/#<passada>]
#<passada>=[#<TOTAL>/#<NUM_D_PASS>]
O<DIRETO1>ELSE
#<acaba>=2
O<DIRETO1>ENDIF
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;


#<diam_raio>=[#<diam_fina_dsb>+[2*#<raio_fundu>]]
#<x_ini>=#<diam_ini>
#<corr_z>=0

o<dsb1>if[#<acaba>ne2]

O100 while [#<NUM_D_PASS> Gt 0]

o<calcula>if[#<diam_ini>lt#<diam_raio>]
#<cateto>=[[#<diam_raio>-#<diam_ini>]/2]
#<corr_z>=[#<raio_fundu>-sqrt[abs[[#<raio_fundu>*#<raio_fundu>]-[#<cateto>*#<cateto>]]]]
o<calcula>endif

G00 X[#<diam_ini>]
G0 Z[#<z_ini>+#<recuo_z>]
G01 F#<f_dsb> Z[#<prof_z>+#<sobre_z>+#<corr_z>]
X[#<diam_ini>+#<recuo_x>]
G0Z[#<z_ini>+#<recuo_z>]
#<diam_ini>=[#<diam_ini>-#<passada>]
#<NUM_D_PASS>=[#<NUM_D_PASS>-1]
O100 endwhile

o<dsb1>endif




o<acaba1>if[#<acaba>ne0]

                                 o<chanfro1>if[#<canto>NE0]


O<CH1>IF[#<canto>GT0]
G00 X[#<diam_fina>-[#<canto>*2]]
G0Z[#<z_ini>+#<recuo_z>]
G01 F[#<f_acab>] Z#<z_ini>
Z[#<z_ini>-#<canto>]X#<diam_fina>
Z[#<prof_z>+#<raio_fundu>]X[#<diam_fina>+#<CONI>]
g02x#<diam_raio> Z#<prof_z> r#<raio_fundu>
g01X[#<x_ini>+#<recuo_x>]
G0Z[#<z_ini>+#<recuo_z>]


O<CH1>ELSE

#<cantu>=ABS[#<canto>]

G00 X[#<diam_fina>-[#<cantu>*2]]
G0Z[#<z_ini>+#<recuo_z>]
G01 F[#<f_acab>] Z#<z_ini>
G03 Z[#<z_ini>-#<cantu>]X#<diam_fina> R#<cantu>
g01Z[#<prof_z>+#<raio_fundu>]X[#<diam_fina>+#<CONI>]
g02 x#<diam_raio> Z#<prof_z> r#<raio_fundu>
g01X[#<x_ini>+#<recuo_x>]
G0Z[#<z_ini>+#<recuo_z>]

O<CH1>ENDIF


                                 o<chanfro1>else
G00 X[#<diam_fina>]
G0Z[#<z_ini>+#<recuo_z>]
g01Z[#<prof_z>+#<raio_fundu>]X[#<diam_fina>+#<CONI>]
g02 x#<diam_raio> Z#<prof_z> r#<raio_fundu>
g01X[#<x_ini>+#<recuo_x>]
G0Z[#<z_ini>+#<recuo_z>]

                                 o<chanfro1>endif

o<acaba1>endif


