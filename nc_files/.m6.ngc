o<.m6> sub

#<tool> = #<_selected_tool>

o<erro2> if [#<tool> GT 16]
  (msg,Ferramenta Pedida Nao Existe)
  G4 P1
  M2
o<erro2> endif
o<erro3> if [#<tool> LE 0]
  (msg,Ferramenta Pedida Nao Existe)
  G4 P1
  M2
o<erro3> endif

; Se a ferramenta pedida já está no spindle, pula a troca física
; mas sincroniza #31 com a posição física real antes de retornar
o<ja_tem> if [#<tool> EQ #<_current_tool>]
  #31 = [#<tool> - 8 * FIX[#<tool> / 9]]
  M6 T#<tool>
  G43 H#<tool>
  G18 G7 G90 G95
  o<.m6> return
o<ja_tem> endif

; #31 = posição atual da torre (1-8), persistente no linuxcnc.var
; Se inválido (0 ou fora de range), assume posição 1
o<initpos> if [#31 LT 1]
  #31 = 1
o<initpos> endif
o<initpos2> if [#31 GT 8]
  #31 = 1
o<initpos2> endif

#<pocket> = [#<tool> - 8 * FIX[#<tool> / 9]]

M64 P6
M64 P7
G4 P3

#<tombos> = [#<pocket> - #31]

o<aj1> if [#<tombos> GT 4]
  #<tombos> = [#<tombos> - 8]
o<aj1> endif
o<aj2> if [#<tombos> LT -4]
  #<tombos> = [#<tombos> + 8]
o<aj2> endif

#<angulo> = [#<tombos> * 45.0]

G91
G0 C#<angulo>
G90

G4 P2

; Atualiza posição persistente APÓS o giro completar
#31 = #<pocket>

M65 P6
M65 P7

G4 P1

M6 T#<tool>
G43 H#<tool>

G18 G7 G90 G95

o<.m6> endsub
M2
