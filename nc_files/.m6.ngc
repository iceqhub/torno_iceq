o<.m6> sub

#<tool> = #<_selected_tool>

o<erro2> if [#<tool> GT 16]
  (msg,Ferramenta Pedida Nao Existe)
  G4 P1
  M2
o<erro2> endif
o<erro3> if [#<tool> LE 0]
  (msg,Ferramenta Pedida Nao Existe)
  G4 P1
  M2
o<erro3> endif

; #<_torre> = posição atual da torre (1-8)
; Carregado do torre.txt pelo Python no __init__
; Salvo no torre.txt pelo Python no __delete__ ao fechar

o<initpos> if [#<_torre> LT 1]
  #<_torre> = 1
o<initpos> endif
o<initpos2> if [#<_torre> GT 8]
  #<_torre> = 1
o<initpos2> endif

; Se a ferramenta pedida já está no spindle, pula a troca física
; mas atualiza #<_torre> para manter consistência
o<ja_tem> if [#<tool> EQ #<_current_tool>]
  #<_torre> = [#<tool> - 8 * FIX[#<tool> / 9]]
  M6 T#<tool>
  G43 H#<tool>
  G18 G7 G90 G94
  o<.m6> return
o<ja_tem> endif

#<pocket> = [#<tool> - 8 * FIX[#<tool> / 9]]

M64 P6
M64 P7
G4 P3

#<tombos> = [#<pocket> - #<_torre>]

o<aj1> if [#<tombos> GT 4]
  #<tombos> = [#<tombos> - 8]
o<aj1> endif
o<aj2> if [#<tombos> LT -4]
  #<tombos> = [#<tombos> + 8]
o<aj2> endif

#<angulo> = [#<tombos> * 45.0]

G91
G0 C#<angulo>
G90

G4 P2

; Atualiza posição da torre — salva ao fechar o LinuxCNC
#<_torre> = #<pocket>

M65 P6
M65 P7

G4 P1

M6 T#<tool>
G43 H#<tool>

G18 G7 G90 G94

o<.m6> endsub
M2
