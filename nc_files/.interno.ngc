(info: Desbaste interno)
o<.interno> sub

#<diam_ini>=#1      (=15 DIAM INI)
#<diam_fina>=#2    (=50 DIAM FINAL)
#<passada>=#3    (=1.5 PASSADA )
#<prof_z>=#4  (=-20 PROF Z ABS)
#<z_ini>=#5   (=0 Z INICIAL)
#<recuo_z>=#6   (=2 RECUO Z)
#<sobre_x>=#7    (=1.3 SOBREMETAL X)
#<sobre_z>=#8    (=0.05 SOBREMETAL Z)
#<CONI>=#9    (=0.00 CONICIDADE)
#<acaba>=#10    (=1 ACA 1=S 0=N 2=SÓ ACA)
#<canto>=#11    (=2 CANTO +=CHANFRO -=RAIO)
#<f_dsb>=#12   (=0.2 AVANÇO DSB)
#<f_acab>=#13   (=0.15 AVANÇO ACAB)
#<vcc>=#14   (=0 VCC)
#<RPM>=#15   (=1500 RPM)
#<PONTO_TROCA_X>=#16  (=80 PONTO DE TROCA X)
#<PONTO_TROCA_Z>=#17  (=80 PONTO DE TROCA Z)
#<TOOL>=#18  (=0 NUMERO DA FERRAMENTA)
#<M8>=#19  (=8 OLEO SOLUVEL 9 DESLIGA)
#<recuo_x>=#20   (=1 RECUO EM X NO CICLO)
#<facea>=#21   (=0 FACEA FUNDO)
#<final_pt>=#22   (=3 FINAL PONTO DE TROCA 0=NAO 1=XZ 2=ZX 3=JUNTOS)





O<aff>IF[#19eq0]
#<recuo_x>=2
O<aff>ENDIF


O<G94>IF[#<f_dsb>GT1]
G94
O<G94>ELSE
G95
O<G94>ENDIF



O<TROCA>IF[#<TOOL>GT0]
G43H#<TOOL>
G00G90X#<PONTO_TROCA_X>Z#<PONTO_TROCA_Z>
T[#<TOOL>]M6G43
O<TROCA>ENDIF


o<m3>if[#<RPM>lt0]

O<RPM>IF[abs[#<vcc>]EQ0]
G97S[abs[#<RPM>]]M4
O<RPM>ENDIF

O<VCC>IF[abs[#<vcc>]GT0]
G96S[abs[#<vcc>]]D[abs[#<RPM>]]M4
O<VCC>ENDIF

o<m3>else


O<RPM>IF[abs[#<vcc>]EQ0]
G97S[abs[#<RPM>]]M3
O<RPM>ENDIF

O<VCC>IF[abs[#<vcc>]GT0]
G96S[abs[#<vcc>]]D[abs[#<RPM>]]M3
O<VCC>ENDIF


o<m3>endif





M#<M8>


o<esquerdo>if[#<diam_ini>gt0]

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AJUSTE;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
#<diam_fina_dsb>=[#<diam_fina>-#<sobre_x>]
#<TOTAL>=[#<diam_fina_dsb>-#<diam_ini>]
O<DIRETO>IF[#<TOTAL>GT#<passada>]
#<NUM_D_PASS>=ROUND[#<TOTAL>/#<passada>]
#<passada>=[#<TOTAL>/#<NUM_D_PASS>]
O<DIRETO>ELSE
#<acaba>=2
O<DIRETO>ENDIF
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;





#<x_ini>=#<diam_ini>

o<dsb>if[#<acaba>ne2]

O100 while [#<NUM_D_PASS> GE 0]
G00 X[#<diam_ini>]
G0 Z[#<z_ini>+#<recuo_z>]
G01 F#<f_dsb> Z[#<prof_z>+#<sobre_z>]
X[#<diam_ini>-#<recuo_x>]
G0Z[#<z_ini>+#<recuo_z>]
#<diam_ini>=[#<diam_ini>+#<passada>]
#<NUM_D_PASS>=[#<NUM_D_PASS>-1]
O100 endwhile

o<dsb>endif

o<acaba>if[#<acaba>ne0]

                                 o<chanfro>if[#<canto>NE0]

O<CH>IF[#<canto>GT0]
G00 X[#<diam_fina>+[#<canto>*2]]
G0Z[#<z_ini>+#<recuo_z>]
G01 F[#<f_acab>] Z#<z_ini>
Z[#<z_ini>-#<canto>]X#<diam_fina>
Z#<prof_z> X[#<diam_fina>-#<CONI>]
O<FACEA>IF[#<facea>EQ1]
X[#<x_ini>-#<recuo_x>]
O<FACEA>ELSE
X[#<diam_fina>-#<recuo_x>]
O<FACEA>ENDIF
G0Z[#<z_ini>+#<recuo_z>]


O<CH>ELSE

#<canto>=ABS[#<canto>]

G00 X[#<diam_fina>+[#<canto>*2]]
G0Z[#<z_ini>+#<recuo_z>]
G01 F[#<f_acab>] Z#<z_ini>
G02 Z[#<z_ini>-#<canto>]X#<diam_fina> R#<canto>
G01 Z#<prof_z> X[#<diam_fina>-#<CONI>]
O<FACE>IF[#<facea>EQ1]
X[#<x_ini>-#<recuo_x>]
O<FACE>ELSE
X[#<diam_fina>-#<recuo_x>]
O<FACE>ENDIF
G0Z[#<z_ini>+#<recuo_z>]
O<CH>ENDIF






                                 o<chanfro>else
G00 X[#<diam_fina>]
G0Z[#<z_ini>+#<recuo_z>]
G01 F[#<f_acab>] Z#<prof_z> X[#<diam_fina>-#<CONI>]
O<FACEA1>IF[#<facea>EQ1]
X[#<x_ini>-#<recuo_x>]
O<FACEA1>ELSE
X[#<diam_fina>-#<recuo_x>]
O<FACEA1>ENDIF
G0Z[#<z_ini>+#<recuo_z>]
                                 o<chanfro>endif

o<acaba>endif



o<esquerdo>else



;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AJUSTE;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
#<diam_fina_dsb>=[#<diam_fina>+#<sobre_x>]
#<TOTAL>=[abs[#<diam_fina_dsb>]-abs[#<diam_ini>]]

O<DIRETO2>IF[#<TOTAL>GT#<passada>]
#<NUM_D_PASS>=ROUND[#<TOTAL>/#<passada>]
#<passada>=[#<TOTAL>/#<NUM_D_PASS>]
O<DIRETO2>ELSE
#<acaba>=2
O<DIRETO2>ENDIF
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;




#<x_ini>=#<diam_ini>

o<dsb2>if[#<acaba>ne2]

O1001 while [#<NUM_D_PASS> GE 0]
G00 X[#<diam_ini>]
G0 Z[#<z_ini>+#<recuo_z>]
G01 F#<f_dsb> Z[#<prof_z>+#<sobre_z>]
X[#<diam_ini>+#<recuo_x>]
G0Z[#<z_ini>+#<recuo_z>]
#<diam_ini>=[#<diam_ini>-#<passada>]
#<NUM_D_PASS>=[#<NUM_D_PASS>-1]
O1001 endwhile

o<dsb2>endif

o<acaba2>if[#<acaba>ne0]

                                        o<chanfro2>if[#<canto>NE0]


O<CH2>IF[#<canto>GT0]
G00 X[#<diam_fina>-[#<canto>*2]]
G0Z[#<z_ini>+#<recuo_z>]
G01 F[#<f_acab>] Z#<z_ini>
Z[#<z_ini>-#<canto>]X#<diam_fina>
Z#<prof_z> X[#<diam_fina>+#<CONI>]
O<FACEA2>IF[#<facea>EQ1]
X[#<x_ini>+#<recuo_x>]
O<FACEA2>ELSE
X[#<diam_fina>+#<recuo_x>]
O<FACEA2>ENDIF
G0Z[#<z_ini>+#<recuo_z>]
O<CH2>ELSE

#<canto>=ABS[#<canto>]

G00 X[#<diam_fina>-[#<canto>*2]]
G0Z[#<z_ini>+#<recuo_z>]
G01 F[#<f_acab>] Z#<z_ini>
G03Z[#<z_ini>-#<canto>]X#<diam_fina> R#<canto>
G01Z#<prof_z> X[#<diam_fina>+#<CONI>]
O<FACEA2>IF[#<facea>EQ1]
X[#<x_ini>+#<recuo_x>]
O<FACEA2>ELSE
X[#<diam_fina>+#<recuo_x>]
O<FACEA2>ENDIF
G0Z[#<z_ini>+#<recuo_z>]
O<CH2>ENDIF




                                        o<chanfro2>else
G00 X[#<diam_fina>]
G0Z[#<z_ini>+#<recuo_z>]
G01 F[#<f_acab>] Z#<prof_z> X[#<diam_fina>+#<CONI>]
O<FACEA3>IF[#<facea>EQ1]
X[#<x_ini>+#<recuo_x>]
O<FACEA3>ELSE
X[#<diam_fina>+#<recuo_x>]
O<FACEA3>ENDIF

G0Z[#<z_ini>+#<recuo_z>]
                                        o<chanfro2>endif

o<acaba2>endif












o<esquerdo>endif






O<TROCA_FIM>IF[#<final_pt>NE0]

O<AMBOS>IF[#<final_pt>EQ3]
G00G90X#<PONTO_TROCA_X>Z#<PONTO_TROCA_Z>
O<AMBOS>ENDIF

O<XZ>IF[#<final_pt>EQ1]
G00G90X#<PONTO_TROCA_X>
Z#<PONTO_TROCA_Z>
O<XZ>ENDIF

O<ZX>IF[#<final_pt>EQ2]
G00G90Z#<PONTO_TROCA_Z>
X#<PONTO_TROCA_X>
O<ZX>ENDIF

O<TROCA_FIM>ENDIF



o<.interno> endsub

